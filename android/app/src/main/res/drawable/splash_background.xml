<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#311737"
                android:centerColor="#1B101E"
                android:endColor="#110A13" />
        </shape>
    </item>
    <item android:gravity="center">
        <shape android:shape="oval">
            <size android:width="240dp" android:height="240dp" />
            <solid android:color="#1EF1C27D" />
        </shape>
    </item>
    <item android:gravity="center">
        <shape android:shape="rectangle">
            <size android:width="124dp" android:height="124dp" />
            <corners android:radius="36dp" />
            <gradient
                android:angle="315"
                android:startColor="#F1C27D"
                android:centerColor="#F2897D"
                android:endColor="#B79CF7" />
        </shape>
    </item>
</layer-list>
